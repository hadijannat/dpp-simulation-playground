{
  "name": "dpp-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "contract:check": "npm run typegen && git diff --exit-code -- src/types/generated/platform-api.ts && node scripts/check-api-contracts.mjs",
    "test:e2e": "playwright test",
    "typegen": "openapi-typescript ../docs/api/openapi/platform-api.yaml -o src/types/generated/platform-api.ts",
    "test": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-query": "5.100.9",
    "i18next": "^26.0.6",
    "keycloak-js": "26.2.4",
    "monaco-editor": "0.55.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "7.15.1",
    "reactflow": "11.11.4",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.1.0",
    "globals": "17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.9.3",
    "vite": "^8.0.14",
    "vitest": "4.1.4",
    "web-vitals": "^5.2.0"
  }
}
